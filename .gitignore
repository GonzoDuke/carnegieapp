# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local settings (machine-specific permissions)
.claude/

# Local-only operator notes (user passcodes, recovery commands, etc.)
USERS.md
JMK.md
TESTER_GUIDE.md
COSTS.md
PLAYBOOK.md

# Playwright e2e artifacts — recordings, traces, reports
/test-results
/playwright-report
/playwright/.cache

# Vision eval harness — local photos, truth labels, and baselines.
# .gitkeep files in each folder are tracked so a fresh clone has the
# scaffold ready; everything else local.
eval/photos/*
!eval/photos/.gitkeep
eval/truth/*
!eval/truth/.gitkeep
eval/baseline*.json
eval/_*.log
